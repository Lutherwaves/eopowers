#!/usr/bin/env bash
set -euo pipefail

session_context="<IMPORTANT>\nBloxPowers е инсталиран.\n\nНалични инструменти за обществени поръчки:\n- /eop-scan — сканиране на eop.bg за отворени строителни поръчки\n- /eop-analyze <id> — анализ на конкретна поръчка\n- /eop-price <id> — ценообразуване\n- /eop-generate <id> — генериране на оферта\n- /eop-review <id> — преглед и PDF конвертиране\n\nНастройка: /init | Меню: /start\n</IMPORTANT>"

if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context"
else
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
fi

exit 0
